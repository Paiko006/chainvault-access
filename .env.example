# ChainVault Environment Variables
# =========================================
# API Key dari Geomi (https://geomi.dev)
# Format Client Key  : AG-XXXXXXXXXXXX  (untuk browser/dapp — gunakan ini!)
# Format Server Key  : aptoslabs_XXXXX  (untuk backend saja)
#
# Cara buat: geomi.dev → Login → API Resource → Network: Testnet
# WAJIB centang "Client Usage" lalu daftarkan URL: http://localhost:8080
# =========================================
VITE_SHELBY_API_KEY=AG-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OPSIONAL: Key yang sama bisa dipakai untuk Aptos node API
VITE_APTOS_API_KEY=AG-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
